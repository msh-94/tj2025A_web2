<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="example.종합.실습4.BookMapper">
    <!-- 단일 등록 -->
    <insert id="bookAdd" parameterType="example.종합.실습4.BookDto" useGeneratedKeys="true" keyProperty="sno">
        insert into books(id , title , stock) values(#{id} , #{title} , #{stock})
    </insert>
    <!-- 대출기록조회 -->
    <select id="rentalPrint" parameterType="String" resultType="list">
        select * from books
        <where>
            <if test="title != null">
                and title = #{title}
            </if>
        </where>
    </select>
    <!-- 일괄 등록 -->
    <insert id="bookAllAdd" parameterType="list" useGeneratedKeys="true" keyProperty="id">
        insert into books(id, title, stock) values
            <foreach collection="list" item="b" separator=",">
                ( #{b.id} , #{b.title}, #{b.stock} )
            </foreach>
    </insert>
</mapper>